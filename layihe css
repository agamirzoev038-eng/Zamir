body{
  background:#f3f3f3;
  font-family:Arial;
}

h1{
  text-align:center;
}

.cards{
  display:flex;
  gap:20px;
  justify-content:center;
}

.card{
  width:250px;
  background:white;
  border-radius:15px;
  padding:10px;
}

.card img{
  width:100%;
  height:250px;
  border-radius:15px;
  object-fit:cover;
}

.card h2{
  font-size:25px;
}

.card p{
  color:blue;
}
